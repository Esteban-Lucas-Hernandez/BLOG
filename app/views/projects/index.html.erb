<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h2 fw-bold mb-0">Proyectos</h1>
  <%= link_to "Nuevo Proyecto", new_project_path, class: "btn btn-primary shadow-sm" %>
</div>

<div class="card mb-4 border-0 shadow-sm">
  <div class="card-body">
    <%= form_with url: projects_path, method: :get, local: true, class: "row g-3 align-items-center" do |form| %>
      <div class="col-auto">
        <%= form.label :status, "Filtrar por estado:", class: "col-form-label fw-medium" %>
      </div>
      <div class="col-auto">
        <%= form.select :status, options_for_select([['Todos', ''], ['Activos', 'active'], ['Pausados', 'paused'], ['Completados', 'completed']], params[:status]), {}, class: "form-select" %>
      </div>
      <div class="col-auto">
        <%= form.submit "Filtrar", class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="projects">
  <% @projects.each do |project| %>
    <div class="col">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <h5 class="card-title fw-bold mb-0 text-truncate" style="max-width: 80%;"><%= project.title %></h5>
            <span class="badge rounded-pill <%= project.status == 'active' ? 'bg-success' : (project.status == 'paused' ? 'bg-warning' : 'bg-secondary') %>">
              <%= project.status.capitalize %>
            </span>
          </div>
          <p class="text-muted small mb-3"><i class="bi bi-person-fill me-1"></i><%= project.client.name %></p>
          
          <div class="mb-3">
            <div class="d-flex justify-content-between small text-muted mb-1">
              <span>Progreso</span>
              <span><%= project.progress_percentage %>%</span>
            </div>
            <div class="progress" style="height: 6px;">
              <div class="progress-bar <%= project.progress_percentage == 100 ? 'bg-success' : 'bg-primary' %>" role="progressbar" style="width: <%= project.progress_percentage %>%;" aria-valuenow="<%= project.progress_percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
          </div>
          
          <%= link_to "Ver Detalles", project, class: "btn btn-sm btn-outline-primary w-100 mt-2" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
