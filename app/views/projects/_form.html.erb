<%= form_with(model: project, class: "card border-0 shadow-sm") do |form| %>
  <div class="card-body">
    <% if project.errors.any? %>
      <div class="alert alert-danger">
        <h6 class="alert-heading fw-bold"><%= pluralize(project.errors.count, "error") %> impidieron guardar:</h6>
        <ul class="mb-0 small">
          <% project.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= form.label :title, "Título del Proyecto", class: "form-label fw-medium" %>
      <%= form.text_field :title, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= form.label :status, "Estado", class: "form-label fw-medium" %>
      <%= form.select :status, [['Activo', 'active'], ['Pausado', 'paused'], ['Completado', 'completed']], {}, class: "form-select" %>
    </div>

    <div class="mb-4">
      <%= form.label :client_id, "Cliente", class: "form-label fw-medium" %>
      <%= form.collection_select :client_id, Client.all, :id, :name, { prompt: "Selecciona un cliente" }, class: "form-select" %>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
      <%= link_to "Cancelar", projects_path, class: "btn btn-light" %>
      <%= form.submit "Guardar Proyecto", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
