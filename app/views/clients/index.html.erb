<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h2 fw-bold mb-0">Clientes</h1>
  <%= link_to "Nuevo Cliente", new_client_path, class: "btn btn-primary shadow-sm" %>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">Nombre</th>
            <th>Email</th>
            <th>Proyectos Activos</th>
            <th class="pe-4 text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @clients.each do |client| %>
            <tr>
              <td class="ps-4 fw-medium"><%= client.name %></td>
              <td><a href="mailto:<%= client.email %>" class="text-decoration-none"><%= client.email %></a></td>
              <td>
                <span class="badge bg-primary rounded-pill"><%= client.projects.where(status: 'active').count %></span>
              </td>
              <td class="pe-4 text-end">
                <%= link_to "Ver", client, class: "btn btn-sm btn-outline-secondary me-1" %>
                <%= link_to "Editar", edit_client_path(client), class: "btn btn-sm btn-outline-primary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
